package Main;
import Core.Output;

function greet(string who): string {
    return "Hello, {who}!";
}

function main(): void {
    string name = "Phorj";
    int n = 3;
    float pi = 3.14;
    Output.printLine("name = {name}, n = {n}, pi = {pi}");
    Output.printLine("n + 1 = {n + 1}");
    Output.printLine(greet(name));

    // bind first — the interpolation sub-lexer does not nest string literals inside {…}
    string w = "world";
    Output.printLine("nested call: {greet(w)}");
}