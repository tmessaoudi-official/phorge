package Main;
import Core.Console;
import Core.List;

class Point {
    constructor(private int x, private int y) {}
    function show() -> string { return "({x}, {y})"; }
}

function main() -> void {
    List<int> nums = [10, 20, 30];
    int count = List.length(nums);  // → PHP count(); generic over the element type
    Console.println("count = {count}");
    for (int n in nums) {
        Console.println("n = {n}");
    }

    List<List<int>> grid = [[1, 2], [3, 4]];
    for (List<int> row in grid) {
        for (int v in row) {
            Console.println("v = {v}");
        }
    }

    List<Point> pts = [Point(0, 0), Point(1, 2)];
    for (Point p in pts) {
        Console.println(p.show());
    }
}